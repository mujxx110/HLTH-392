<script>
const Q=[
{sec:"Multiple choice",type:"mc",stem:"Scottie experiences extreme sadness and grief after losing his brother. He reaches out to friends for support and recognizes that his feelings are normal and temporary. Which elements of mental health best describe what Scottie has employed?",opts:["Hopefulness and meaning","Cognitive resources","Social skills and emotional resources","Emotional resources and connectedness"],ans:2,exp:"Scottie draws on both social resources (reaching out to friends — connectedness) and emotional resources (recognizing the normalcy of grief, regulating his response). The in-class trivia confirmed D: social skills and emotional resources."},
{sec:"Multiple choice",type:"mc",stem:"Which of the following scenarios most strongly supports the dual continua model over the bipolar model of mental health?",opts:["A study finds a perfect negative correlation (r = −1.00) between anxiety symptoms and wellbeing scores","A therapeutic intervention results in some individuals improving in mental health but not in mental illness symptoms, and vice versa","An intervention reduces depressive symptoms and all participants simultaneously show increased life satisfaction","A population with low rates of mental illness reports uniformly high flourishing scores"],ans:1,exp:"The dual continua model holds that mental health and mental illness are related but distinct constructs — you can improve on one without necessarily improving on the other. Option B demonstrates exactly this independence. A perfect negative correlation (option A) would actually support the bipolar model."},
{sec:"Multiple choice",type:"mc",stem:"Ramon has a diagnosis of bipolar disorder and requires weekly psychotherapy and a strict medication regime. He maintains steady employment and experiences joy through community volunteering. Which statement best describes his situation?",opts:["Moderate mental health, moderate symptoms of mental illness","Complex mental illness","Good mental health, ongoing treatment of mental illness","Good mental health, no mental illness"],ans:2,exp:"Ramon has ongoing mental illness requiring active treatment, but his mental health — his ability to function, find meaning, and connect socially — is good. This is the top-right quadrant of the dual continua model (good MH, mental illness present)."},
{sec:"Multiple choice",type:"mc",stem:"Which of the following best represents a 'focusing event' in mental health policy?",opts:["A government releasing a 10-year mental health strategy","A psychiatrist updating their clinical guidelines","A high-profile mass shooting that draws political attention to gaps in community mental health services","A university adopting a stepped care model for student supports"],ans:2,exp:"A focusing event is a dramatic incident that shifts public and political attention to a systemic issue and creates a window for policy change. The Tumbler Ridge shooting used in the Week 6 lecture is the canonical example from this course."},
{sec:"Multiple choice",type:"mc",stem:"Which of the following is a meso-level policy in Ontario's mental health system?",opts:["The Canada Health Act","The Health Care Consent Act","A hospital's internal documentation protocol for suicide risk","CANMAT treatment guidelines for depression"],ans:1,exp:"Meso policies govern 'middle' jurisdictions between federal frameworks and organizational micro-policies — provincial legislation like the HCCA fits here. The Canada Health Act is macro. Hospital protocols are micro. CANMAT is a clinical practice guideline, not a government policy."},
{sec:"Multiple choice",type:"mc",stem:"An Early Years Centre provides parents with positive parenting models, connections to social supports, and access to health resources. What term best describes the probable outcome of this service?",opts:["Building parental mental health","Treating parental mental illness","Supporting mental health and treating mental illness","Preventing mental health and mental illness deterioration"],ans:3,exp:"This type of upstream, population-level programming targets prevention — preventing deterioration of both mental health and the onset or worsening of mental illness. The in-class trivia confirmed D."},
{sec:"Multiple choice",type:"mc",stem:"Under the Ontario MHA, which type of patient is admitted through consent given by a substitute decision maker and is most commonly a person under 16?",opts:["Voluntary patient","Informal patient","Involuntary patient","Court-ordered patient"],ans:1,exp:"An informal patient is admitted under SDM consent via section 24 of the HCCA. In practice this process is used for persons under 16. Persons 16 and older who object to admission require a guardian or attorney for personal care with explicit authority."},
{sec:"Multiple choice",type:"mc",stem:"Best practice discharge guidance after psychiatric hospitalization recommends follow-up with a psychiatrist within how many days?",opts:["7 days","14 days","30 days","48 hours"],ans:0,exp:"Best practice guidance recommends psychiatrist follow-up within 7 days of discharge. Primary care follow-up is recommended within 30 days. Both targets aim to reduce psychiatric readmissions after hospital discharge."},
{sec:"Multiple choice",type:"mc",stem:"Collaborative mental healthcare (CMHC) as described in the Kates reading is best characterized by which combination of features?",opts:["Specialist-based referrals, hospital-centred care, diagnosis-focused treatment","Shared goals, regular cross-provider communication, measurement-based and person-centred care","Individual clinician discretion, episodic care, and condition-specific treatment","Population screening, inpatient stabilization, and discharge planning"],ans:1,exp:"CMHC integrates family physicians and mental health providers through shared goals, shared care plans, regular communication, measurement-based care, and a strong emphasis on person- and family-centred approaches. It is explicitly designed to move away from specialist-based hospital-centred care."},
{sec:"Multiple choice",type:"mc",stem:"In a stepped care model, what happens as you move up the steps?",opts:["Increased service complexity, higher needs, affects fewer people in the population","Increased service complexity, higher needs, affects more people in the population","Decreased service complexity, higher needs, affects fewer people","Increased service complexity, fewer needs, affects more people"],ans:0,exp:"As steps increase: services become more intensive and specialized, client needs are more severe, and fewer people in the population require that level of care. Prevention at the base (step 1) affects everyone; inpatient care at the top affects very few."},
{sec:"Multiple choice",type:"mc",stem:"The Ontario Mental Health Reporting System (OMHRS) collects data on every person admitted to inpatient psychiatry in Ontario since 2005. Approximately how many variables does it cover per admission?",opts:["50","150","500","5000"],ans:2,exp:"The OMHRS covers approximately 500 variables per admission, including mental health symptoms, functional status, social relationships, school and work functioning, interventions, physical health, and living arrangements at both admission and discharge."},
{sec:"Multiple choice",type:"mc",stem:"According to Hirdes et al., which of the following is the primary clinical purpose of interRAI's Clinical Assessment Protocols (CAPs)?",opts:["To diagnose psychiatric conditions based on symptom clusters","To support care planning by triggering clinical responses linked to recovery goals","To generate billing codes for insured mental health services","To replace clinical judgment with algorithmic decision-making"],ans:1,exp:"CAPs are care planning guidelines triggered by assessment data — they identify focal domains requiring intervention and link to evidence-based actions supporting recovery. InterRAI explicitly frames itself as not a diagnostic system and not a replacement for clinical judgment."},
{sec:"Multiple choice",type:"mc",stem:"Which interRAI instrument is specifically designed for use by police officers and emergency medical services as a first-line contact tool?",opts:["interRAI Community Mental Health","interRAI Emergency and Crisis Services","interRAI for Police, EMS, and Other Non-Mental Health Settings","interRAI Check-Up Self-Report"],ans:2,exp:"The interRAI instrument for Police, EMS, and Other Non-Mental Health Settings was designed for non-mental health professionals as a systematic observation tool. It includes three patient safety algorithms (harm to self, harm to others, inability to care for self) and uses a 34-hour lookback period."},
{sec:"Multiple choice",type:"mc",stem:"Which of the following study findings from the Gomes et al. (2022) reading is most relevant to justifying the expansion of SOS programs from a health economics perspective?",opts:["No opioid-related deaths were observed among SOS program participants","Healthcare costs declined from approximately $15,635 to $7,310 per person-year after SOS entry","Hospital admissions for new infections declined 49%","Emergency department visits declined 31% after SOS entry"],ans:1,exp:"While all findings support SOS expansion, the cost reduction from ~$15,635 to ~$7,310 per person-year is the most direct health economics argument — it demonstrates that providing prescribed opioids and wrap-around care is substantially cheaper than the downstream healthcare costs of unmanaged street drug use."},
{sec:"Multiple choice",type:"mc",stem:"The Ontario government's HART Hubs were introduced following policy changes including the Safer Streets, Stronger Communities Act. Which of the following services do HART Hubs explicitly NOT offer?",opts:["Treatment and recovery services","Safer supply programs","Connections to housing supports","Partnerships across multiple ministries"],ans:1,exp:"The government explicitly stated that HART Hubs will not offer safer supply, supervised consumption, or needle exchange programs. They are focused on treatment and recovery."},
{sec:"Multiple choice",type:"mc",stem:"What does the evidence from the scoping review of decriminalization studies suggest is needed alongside decriminalization for it to meaningfully improve health outcomes?",opts:["Stricter sentencing for drug trafficking","Funding for treatment, housing, and other wraparound supports","Mandatory addiction treatment programs","Increased police discretion in enforcement"],ans:1,exp:"The scoping review's key message was: if we pursue decriminalization, we need concurrent funding for treatment, housing, and other supports. Research that only measured prevalence of use misses the health system outcomes that matter."},
{sec:"Multiple choice",type:"mc",stem:"In Ontario, which ministry became responsible for community-based child and youth mental health services in April 2019?",opts:["Ministry of Children Community and Social Services","Ministry of Education","Ministry of Health","Ministry of Long-Term Care"],ans:2,exp:"In April 2019, responsibility for CYMH services transferred from the Ministry of Children and Youth Services (MCYS) to the Ministry of Health (MOH). This consolidated mental health services under a health mandate."},
{sec:"Multiple choice",type:"mc",stem:"The Auditor General found that Ontario CYMH agencies used different tools to assess client needs. Which of the following was identified as an opportunity to address this gap?",opts:["Mandating a single standardized assessment tool used by 40+ agencies including interRAI ChYMH","Allowing each lead agency to develop their own validated tool","Requiring all agencies to use the CAFAS only","Having the MOH develop its own proprietary tool"],ans:0,exp:"The Auditor General highlighted the interRAI ChYMH as an opportunity — already used by 40+ agencies, providing common data, embedded algorithms directing to best practice, embedded scales for severity and risk, and compatibility with the adult interRAI system for continuity across the lifespan."},
{sec:"Multiple choice",type:"mc",stem:"In the Domenech-Abella et al. study, which of the following factors was associated with LOWER mental health among older adults in their sample?",opts:["High social cohesion and high mobility","Being male, having higher education, and being married","Female sex, previously married status, primary education or lower, and limited physical functioning","High social participation and low traffic density"],ans:2,exp:"The study found that female sex, previously married status, lower education, limited physical functioning, low social participation, low social cohesion, poor access to basic services, dense traffic, low mobility, and lack of safety were all associated with lower mental health outcomes."},
{sec:"Multiple choice",type:"mc",stem:"According to the Week 12 guest lecture, the stress buffering hypothesis suggests which of the following?",opts:["Stress itself causes loneliness, which then causes poor health outcomes","The mitigation of stress and its health effects depends on the degree of social support a person has","Loneliness is the primary cause of stress among older adults","Social isolation directly buffers the effects of chronic stress in older adults"],ans:1,exp:"The stress buffering hypothesis states that the degree of social support a person has determines how much stress and its adverse effects are mitigated. Social support acts as a buffer between stressful experiences and health outcomes."},
{sec:"Multiple choice",type:"mc",stem:"A study examined antipsychotic use among people with dementia who did NOT have behavioural or psychotic symptoms. Where was antipsychotic use highest in this population?",opts:["Home care clients","Long-term care nursing home residents","Patients awaiting discharge from acute hospitals (ALC)","Complex continuing care patients"],ans:2,exp:"The study found that the highest and most inexplicable antipsychotic use was among ALC patients — those waiting in hospital for nursing home placement. Even without symptoms, approximately 30% received antipsychotics. The likely explanation is that sedated patients are easier to manage in an acute hospital environment."},
{sec:"Multiple choice",type:"mc",stem:"Which of the following correctly describes the distinction between social isolation and loneliness as used in the Week 12 guest lecture?",opts:["They are synonymous and can be used interchangeably in research","Social isolation is the subjective emotional state; loneliness is the objective measure","Social isolation is the objective measure of being alone; loneliness is the subjective feeling of being isolated","Loneliness only applies to older adults while social isolation applies across the lifespan"],ans:2,exp:"Social isolation = objective (e.g., measured by number of social contacts). Loneliness = subjective (e.g., perceived deficiency in social relationships). They do not always co-occur."},
{sec:"Multiple choice",type:"mc",stem:"A patient with dementia residing in a nursing home is refusing to allow staff to assist with bathing — pushing them away and cursing. Using the lecture's framework, which of the following represents the most evidence-informed first step?",opts:["Prescribe a low-dose antipsychotic to reduce agitation","Restrain the patient during care activities","Investigate underlying causes such as pain, discomfort, or fear before considering medication","Document the behaviour as aggressive and escalate to the care team immediately"],ans:2,exp:"The lecture emphasized that behaviours labelled as 'aggressive' in dementia typically have underlying causes — pain, incontinence, discomfort, fear, or delirium. Evidence-informed care requires investigating these causes before defaulting to antipsychotic medications, which carry significant harms including mortality risk."},
{sec:"True/False",type:"tf",stem:"According to the dual continua model, it is possible to have a mental illness diagnosis while also experiencing good mental health.",ans:true,exp:"True. This is a foundational concept. Mental health (how you feel and function) and mental illness (diagnostic symptoms) operate on separate continua. A person with schizophrenia or dementia can experience good mental health through supports, meaning, and connectedness."},
{sec:"True/False",type:"tf",stem:"Under Ontario's Mental Health Act, a psychiatric designation applies only to the specific unit of a hospital where a patient is admitted, not to the entire facility.",ans:false,exp:"False. The psychiatric designation applies to the entire facility. If an involuntary psychiatric patient is transferred to CT for imaging, they are still considered an involuntary psychiatric patient under the MHA while in that setting."},
{sec:"True/False",type:"tf",stem:"Transinstitutionalization refers to people being discharged from hospitals into the community and accessing robust community-based mental health supports.",ans:false,exp:"False. Transinstitutionalization describes the opposite: people discharged from psychiatric hospitals who do not receive adequate community supports and end up institutionalized elsewhere — most commonly in the prison system."},
{sec:"True/False",type:"tf",stem:"The interRAI suite of mental health assessment instruments was designed primarily as a diagnostic system to classify psychiatric conditions.",ans:false,exp:"False. InterRAI explicitly is not a diagnostic system. Its primary focus is on function, symptoms, strengths, and care planning — not diagnosis. It tracks provisional and finalized diagnoses but does not generate them."},
{sec:"True/False",type:"tf",stem:"According to the Hirdes reading, using specific clinical scales on an 'as-needed' basis is a sound strategy because clinicians are best positioned to determine which issues require measurement.",ans:false,exp:"False. Hirdes explicitly critiques the as-needed approach: we do not always know who has a given problem without asking. This leads to under-detection of issues like pain, depression, and dyspnea. Comprehensive integrated assessment forces clinicians to ask about issues they might otherwise miss."},
{sec:"True/False",type:"tf",stem:"The Gomes et al. SOS study found a significant increase in infection-related hospitalizations among SOS program participants compared to the year before program entry.",ans:false,exp:"False. Admissions for new infections declined 49% among SOS clients in the year after program entry. There was no significant increase in infections — one of the study's key safety findings alongside no opioid-related deaths."},
{sec:"True/False",type:"tf",stem:"Assertive Community Treatment (ACT) was shown in the At Home / Chez Soi trial to be cost-effective only for participants with no prior arrest history.",ans:false,exp:"False. The At Home/Chez Soi trial found the intervention appeared cost-effective regardless of participant sex, alcohol or drug dependence, level of functioning, prior hospitalizations, or prior arrest history."},
{sec:"True/False",type:"tf",stem:"Chile has developed a national real-time suicide surveillance program that tracks deaths by suicide.",ans:true,exp:"True. Confirmed in the Week 9 guest lecture. Chile's surveillance program involves real-time data collection and reporting on suicide mortality — and has been associated with a sustained decline in suicide deaths that persisted through the COVID-19 pandemic."},
{sec:"True/False",type:"tf",stem:"The cannabis paradox for older adults refers to the fact that clinical guidelines recommend cannabis for dementia treatment while research evidence shows adverse outcomes.",ans:false,exp:"False — the paradox is the reverse. Guidelines say to generally avoid cannabis for older adults with cognitive or cardiovascular conditions, while emerging research is trialling cannabis (e.g., THC/CBD oil) as an alternative to antipsychotics for BPSD. Guidelines are cautious; research is exploring therapeutic uses."},
{sec:"True/False",type:"tf",stem:"According to the Auditor General report, Ontario's MOH tracks which standardized assessment tools are being used by individual CYMH agencies.",ans:false,exp:"False. The Auditor General explicitly found that the MOH does not track which tools agencies use. This lack of oversight means the ministry cannot confirm consistent, comparable data on client needs, severity, or outcomes across the sector."},
{sec:"True/False",type:"tf",stem:"A key recommendation from the Auditor General was that MOH consolidate adult and child/youth mental health programs and develop clear timelines, indicators, and targets to measure progress on the Roadmap to Wellness.",ans:true,exp:"True. Despite a 2010 Select Committee recommendation to consolidate mental health programs under one ministry, adult and CYMH systems remain siloed over a decade later. The recommendation was to evaluate consolidation options and establish timelines and measurable targets."},
{sec:"True/False",type:"tf",stem:"In the Domenech-Abella et al. study, the authors hypothesized that social loneliness would be the stronger mediator — but found that emotional loneliness was actually the dominant mediating factor.",ans:true,exp:"True. This was the key finding that contrasted the authors' expectation. Emotional loneliness — lacking close trusting relationships — turned out to be the dominant mediator, particularly for mobility and safety associations."},
{sec:"True/False",type:"tf",stem:"Designing a policy for addressing substance use requires recognition of the reasons why people use drugs — including social, economic, and psychological factors.",ans:true,exp:"True. This was 100% consensus in the in-class trivia. Contemporary evidence-based addiction policy is patient-centred and recognizes that substance use is shaped by complex upstream factors. Ignoring these factors produces policies that only address surface-level behaviour."},
{sec:"True/False",type:"tf",stem:"Rapid Access Addiction Medicine (RAAM) clinics in Ontario require patients to complete a full intake screening form before they can see a physician on the same day.",ans:false,exp:"False. RAAM clinics provide same-day access to physician assessment for addiction — not just screening forms. The defining feature is immediate physician-level assessment, which is what distinguishes them from lower-intensity intake processes."},
{sec:"True/False",type:"tf",stem:"Evidence consistently shows that microaggressions experienced by racialized persons have only an emotional impact and do not produce physiological effects.",ans:false,exp:"False. Microaggressions produce both emotional and physiological effects — chronic stress responses including HPA axis activation, elevated cortisol, and cardiovascular impacts are documented consequences of racial microaggressions."},
{sec:"Short answer",type:"sa",stem:"Explain the concept of conglomeration versus integration of assessment, as described in Hirdes et al. Why does conglomeration lead to problems at both the individual and population level? Give one example of each. (3 marks)",model:"<strong>Conglomeration</strong> refers to systems where clinicians piece together separate intake forms and standalone clinical scales used on an as-needed basis. The data from these systems is typically not automated, not linked across forms, and collected inconsistently depending on which clinician decided which scale was relevant.<br><br><strong>Individual-level problem:</strong> Patients face repetitive measurement of the same issues, and clinically relevant information is not accessible across their circle of care. Longitudinal case histories cannot be constructed. Example: a patient seen in emergency then transferred to inpatient psychiatry has their intake form completed again from scratch because the two forms are not linked.<br><br><strong>Population-level problem:</strong> When different clinicians choose different scales to measure the same construct (e.g., depression), there is no measurement consistency — quality indicators measured differently across organizations have no validity for comparison. Example: one agency uses the PHQ-9 and another uses the Hamilton Depression Scale; their outcome data cannot be meaningfully compared to assess which agency produces better results."},
{sec:"Short answer",type:"sa",stem:"Describe the governance structure for child and youth mental health services in Ontario as it existed at the time of the Auditor General's report. Who funds it, who oversees it, and what were two major coordination gaps identified? (4 marks)",model:"<strong>Governance structure:</strong> The Ministry of Health (MOH) funds 222+ community-based agencies that provide CYMH services. Ontario Health, through the Mental Health and Addictions Centre of Excellence, is responsible for operationalizing the province's strategy (Roadmap to Wellness). Lead agencies (31 total) organize and coordinate services across 31 service areas. Multiple ministries are involved — MOH, MCCSS (child welfare and developmental services), Ministry of Education, and Ministry of Labour — reflecting the intersecting needs of children and youth.<br><br><strong>Gap 1 — addictions services:</strong> CYMH agencies are not funded to deliver addictions services, creating a siloed system where children with concurrent mental health and substance use disorders cannot access integrated care. Agencies reported that clinical staff were not trained for concurrent disorders and no integrated pathways existed.<br><br><strong>Gap 2 — transition to adult services:</strong> Youth approaching 18 face a cliff when aging out of CYMH services. Adult mental health does not have a defined core service framework for mild-moderate illness, and CYMH agencies are not funded to serve clients once they turn 18 — leaving transition-aged youth without continuity of care despite clear evidence that this transition is a high-risk period."},
{sec:"Short answer",type:"sa",stem:"A community mental health organization wants to use interRAI data to compare its outcomes for youth with mental illness against other organizations in Ontario. Explain how interRAI supports this and what two psychometric properties are essential for the data to be meaningful for this purpose. (3 marks)",model:"<strong>How interRAI supports comparison:</strong> Because interRAI instruments use a common language, common item definitions, and common conceptual basis across settings, data collected by different agencies using the same instrument is directly comparable. Quality indicators — such as rate of improvement in symptoms or rate of worsening — can be risk-adjusted and compared at the organization level. The interRAI ChYMH, when used across 40+ Ontario agencies, enables exactly this kind of cross-agency benchmarking.<br><br><strong>Psychometric property 1 — reliability:</strong> Independent assessments by different clinicians must yield consistent answers (inter-rater reliability). Without reliability, differences in scores between organizations might reflect assessor variation rather than genuine differences in client outcomes — making comparison meaningless.<br><br><strong>Psychometric property 2 — validity (specifically convergent and predictive validity):</strong> The scales must measure what they claim to measure and must predict clinically meaningful outcomes (e.g., a high depression score should predict future functional decline or service need). Without validity, comparing quality indicators across organizations does not reflect actual differences in care quality."}
];

let answered={},correct=0,wrong=0;
const total=Q.length;
const autoTf=total-5;

function buildExam(){
const body=document.getElementById('exam-body');
body.innerHTML='';
let sec='';
Q.forEach((q,i)=>{
if(q.sec!==sec){
sec=q.sec;
const sh=document.createElement('div');
sh.className='section-header';
sh.textContent=q.sec+(q.sec==='Multiple choice'?' (1 mark each)':(q.sec==='True/False'?' — True or False':''));
body.appendChild(sh);
}
const card=document.createElement('div');card.className='qcard';card.id='q'+i;
const num=document.createElement('div');num.className='q-num';num.textContent='Question '+(i+1)+' of '+total;card.appendChild(num);
const stem=document.createElement('div');stem.className='q-stem';stem.textContent=q.stem;card.appendChild(stem);
if(q.type==='mc'){
const opts=document.createElement('div');opts.className='options';
q.opts.forEach((o,j)=>{
const b=document.createElement('button');b.className='opt-btn';
b.textContent=(['A','B','C','D'][j])+'. '+o;
b.onclick=()=>answerMC(i,j);opts.appendChild(b);
});
card.appendChild(opts);
}else if(q.type==='tf'){
const row=document.createElement('div');row.className='tf-row';
['True','False'].forEach((t,j)=>{
const b=document.createElement('button');b.className='tf-btn';b.textContent=t;
b.onclick=()=>answerTF(i,j===0);row.appendChild(b);
});
card.appendChild(row);
}else{
const ta=document.createElement('textarea');ta.className='sa-area';ta.placeholder='Write your answer here...';card.appendChild(ta);
const rb=document.createElement('button');rb.className='sa-reveal-btn';rb.textContent='Show model answer';
rb.onclick=()=>revealSA(i,card,q.model);card.appendChild(rb);
}
const fb=document.createElement('div');fb.className='feedback';fb.id='fb'+i;fb.style.display='none';card.appendChild(fb);
body.appendChild(card);
});
}

function answerMC(i,j){
if(answered[i]!==undefined)return;
answered[i]=j;
const q=Q[i];const card=document.getElementById('q'+i);
const btns=card.querySelectorAll('.opt-btn');
const isCorrect=j===q.ans;
btns[j].className='opt-btn '+(isCorrect?'correct':'wrong');
if(!isCorrect)btns[q.ans].className='opt-btn reveal-correct';
btns.forEach(b=>b.disabled=true);
const fb=document.getElementById('fb'+i);fb.style.display='block';
fb.className='feedback '+(isCorrect?'correct':'wrong');
fb.textContent=(isCorrect?'Correct. ':'Incorrect. ')+q.exp;
card.className='qcard '+(isCorrect?'answered-correct':'answered-wrong');
if(isCorrect)correct++;else wrong++;
updateStats();
}

function answerTF(i,val){
if(answered[i]!==undefined)return;
answered[i]=val;
const q=Q[i];const card=document.getElementById('q'+i);
const btns=card.querySelectorAll('.tf-btn');
const isCorrect=val===q.ans;
btns[val?0:1].className='tf-btn '+(isCorrect?'correct':'wrong');
if(!isCorrect)btns[q.ans?0:1].className='tf-btn reveal-correct';
btns.forEach(b=>b.disabled=true);
const fb=document.getElementById('fb'+i);fb.style.display='block';
fb.className='feedback '+(isCorrect?'correct':'wrong');
fb.textContent=(isCorrect?'Correct. ':'Incorrect. ')+q.exp;
card.className='qcard '+(isCorrect?'answered-correct':'answered-wrong');
if(isCorrect)correct++;else wrong++;
updateStats();
}

function revealSA(i,card,model){
const existing=card.querySelector('.model-ans');
if(existing){existing.style.display=existing.style.display==='none'?'block':'none';return;}
const ma=document.createElement('div');ma.className='model-ans';ma.innerHTML=model;card.appendChild(ma);
answered[i]='sa';
updateStats();
}

function updateStats(){
const done=Object.keys(answered).length;
document.getElementById('stat-done').textContent=done;
document.getElementById('stat-correct').textContent=correct;
document.getElementById('stat-wrong').textContent=wrong;
const mc_tf=Q.filter((q,i)=>answered[i]!==undefined&&q.type!=='sa').length;
const pct=mc_tf>0?Math.round((correct/mc_tf)*100)+'%':'—';
document.getElementById('stat-pct').textContent=pct;
document.getElementById('prog').style.width=Math.round((done/total)*100)+'%';
if(done===total){
const rc=document.getElementById('result-card');rc.style.display='block';
document.getElementById('res-score').textContent=correct+'/'+autoTf+' ('+Math.round((correct/autoTf)*100)+'%) on MC + T/F';
const pctN=correct/autoTf;
const msg=document.getElementById('res-msg');
if(pctN>=0.85)msg.textContent='Strong. You have a solid command of this material.';
else if(pctN>=0.70)msg.textContent='Good foundation — revisit the questions you missed and review the flagged readings.';
else msg.textContent='Keep grinding. Focus on the in-class trivia answers and flagged readings.';
}
}

function resetExam(){
answered={};correct=0;wrong=0;
document.getElementById('result-card').style.display='none';
updateStats();buildExam();
}

buildExam();updateStats();
</script>
